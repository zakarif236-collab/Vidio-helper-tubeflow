{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build",
    "start": "tsx server.ts",
    "preview": "vite preview",
    "clean": "rimraf dist",
    "kill": "node ./scripts/stop-firebase-emulators.mjs",
    "seed:maintenance": "node ./scripts/seed-maintenance-config.mjs",
    "seed:maintenance:emulator": "set FIRESTORE_EMULATOR_HOST=127.0.0.1:8081&& node ./scripts/seed-maintenance-config.mjs",
    "lint": "npm run lint:browser-storage && tsc --noEmit",
    "lint:browser-storage": "node ./scripts/check-browser-storage.mjs",
    "preemulators": "npm run kill",
    "emulators": "node ./scripts/start-firebase-emulators.mjs",
    "emulators:restart": "npm run kill && node ./scripts/start-firebase-emulators.mjs"
  },
  "dependencies": {
    "@distube/ytdl-core": "^4.16.12",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "busboy": "^1.4.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.11.0",
    "firebase-admin": "^13.8.0",
    "groq-sdk": "^1.1.2",
    "konva": "^10.2.3",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "natural": "^6.7.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-konva": "^19.2.3",
    "react-router-dom": "^6.17.0",
    "use-image": "^1.1.4",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/qs": "^6.15.0",
    "@types/react-reconciler": "^0.33.0",
    "autoprefixer": "^10.4.21",
    "rimraf": "^5.0.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
